# Date Type Taxonomy
#
# SKOS ConceptScheme for concept date / governance event types.
# MANAGEMENT: these classify governance events in the concept lifecycle.
# Source: ISO 10241-1, TBX (ISO 30042), glossarist config.yml concept_date.type

@prefix gloss: <https://www.glossarist.org/ontologies/> .
@prefix skos:  <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .

gloss:datetype a skos:ConceptScheme ;
  skos:prefLabel "Date Type"@en ;
  skos:definition "MANAGEMENT: Types of governance events in the concept or localization lifecycle."@en ;
  dcterms:source <https://www.glossarist.org/schemas/v3/concept> .

<https://www.glossarist.org/ontologies/datetype/accepted> a skos:Concept ;
  skos:inScheme gloss:datetype ;
  skos:prefLabel "accepted"@en ;
  skos:definition "MANAGEMENT: Date when the concept or localization was accepted."@en .

<https://www.glossarist.org/ontologies/datetype/amended> a skos:Concept ;
  skos:inScheme gloss:datetype ;
  skos:prefLabel "amended"@en ;
  skos:definition "MANAGEMENT: Date when the concept or localization was amended."@en .

<https://www.glossarist.org/ontologies/datetype/retired> a skos:Concept ;
  skos:inScheme gloss:datetype ;
  skos:prefLabel "retired"@en ;
  skos:definition "MANAGEMENT: Date when the concept or localization was retired."@en .

<https://www.glossarist.org/ontologies/datetype/review> a skos:Concept ;
  skos:inScheme gloss:datetype ;
  skos:prefLabel "review"@en ;
  skos:definition "MANAGEMENT: Date when a review was conducted on the localization."@en .

<https://www.glossarist.org/ontologies/datetype/review_decision> a skos:Concept ;
  skos:inScheme gloss:datetype ;
  skos:prefLabel "review decision"@en ;
  skos:definition "MANAGEMENT: Date when a review decision was made on the localization. The event_description field carries the decision narrative."@en .

gloss:datetype skos:hasTopConcept <https://www.glossarist.org/ontologies/datetype/accepted> , <https://www.glossarist.org/ontologies/datetype/amended> , <https://www.glossarist.org/ontologies/datetype/retired> , <https://www.glossarist.org/ontologies/datetype/review> , <https://www.glossarist.org/ontologies/datetype/review_decision> .
