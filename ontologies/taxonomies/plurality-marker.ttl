# Plurality Marker Taxonomy
#
# SKOS ConceptScheme for diagram notation flags on a
# PartitiveHyperedge. Two values: double (close-set double line,
# several parts of same type) and dashed (plurality is uncertain).
# Originates from VIM concept-relationship diagrams.

@prefix gloss:   <https://www.glossarist.org/ontologies/> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .

gloss:pluralityMarker a skos:ConceptScheme ;
  skos:prefLabel "Plurality Marker"@en ;
  skos:definition "Diagram notation flags that travel with a PartitiveHyperedge so the rendering layer can reproduce the source diagram's notation. Originates from VIM concept-relationship diagrams."@en ;
  dcterms:source <https://www.glossarist.org/schemas/v3/concept> .

<https://www.glossarist.org/ontologies/pluralityMarker/double> a skos:Concept ;
  skos:inScheme gloss:pluralityMarker ;
  skos:prefLabel "double"@en ;
  skos:definition "Close-set double line at the receiver end of the rake. Indicates that several partitive concepts of a given type are involved."@en .

<https://www.glossarist.org/ontologies/pluralityMarker/dashed> a skos:Concept ;
  skos:inScheme gloss:pluralityMarker ;
  skos:prefLabel "dashed"@en ;
  skos:definition "Broken or dashed line. Indicates that plurality is uncertain."@en .

gloss:pluralityMarker skos:hasTopConcept
    <https://www.glossarist.org/ontologies/pluralityMarker/double> ,
    <https://www.glossarist.org/ontologies/pluralityMarker/dashed> .
